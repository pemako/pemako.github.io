<h4 id="03-дәҶи§Ј-bytesstr-е’Ң-unicode-зҡ„еҢәеҲ«">03. дәҶи§Ј bytesгҖҒstr е’Ң unicode зҡ„еҢәеҲ«</h4>

<p>python3дёӯжңүдёӨз§ҚиЎЁзӨәеӯ—з¬ҰеәҸеҲ—зҡ„зұ»еһӢпјҡbytes(е®һдҫӢеҢ…еҗ«еҺҹе§Ӣзҡ„8дҪҚеҖј)е’Ң str(е®һдҫӢеҢ…еҗ« Unicode еӯ—з¬Ұ)гҖӮ</p>

<p>python2 дёӯдёӨз§ҚиЎЁзӨәеӯ—з¬ҰеәҸеҲ—зҡ„зұ»еһӢ: str(е®һдҫӢеҢ…еҗ«еҺҹе§Ӣзҡ„8дҪҚеҖј) е’Ң unicode(еҢ…еҗ« Unicodeеӯ—з¬Ұ)гҖӮ</p>

<p>з”ұдәҺеӯ—з¬Ұзұ»еһӢжңүеҲ«пјҢжүҖд»ҘPython д»Јз Ғдёӯз»ҸеёёдјҡеҮәзҺ°дёӨз§Қеёёи§Ғзҡ„дҪҝз”ЁеңәжҷҜпјҡ</p>

<ul>
  <li>ејҖеҸ‘иҖ…йңҖиҰҒеҺҹе§Ӣ8дҪҚеҖјпјҢиҝҷдәӣ8дҪҚзҪ®иЎЁзӨәд»Ҙ UTF-8ж јејҸ(жҲ–е…¶е®ғзј–з ҒеҪўејҸ)жқҘзј–з Ғзҡ„еӯ—з¬Ұ</li>
  <li>ејҖеҸ‘иҖ…йңҖиҰҒж“ҚдҪңжІЎжңүзү№жҖ§зј–з ҒеҪўејҸзҡ„ Unicode еӯ—з¬Ұ</li>
</ul>

<div class="language-python highlighter-rouge"><div class="highlight"><pre class="highlight"><code>
<span class="c1"># python3 дёӯзј–еҶҷдёӨдёӘеё®еҠ©еҮҪж•°
</span>
<span class="k">def</span> <span class="nf">to_str</span><span class="p">(</span><span class="n">bytes_or_str</span><span class="p">):</span>
    <span class="s">"""жҺҘеҸ—strжҲ–bytes,е№¶жҖ»жҳҜиҝ”еӣһstr"""</span>
    <span class="k">if</span> <span class="nb">isinstance</span><span class="p">(</span><span class="n">bytes_or_str</span><span class="p">,</span> <span class="nb">bytes</span><span class="p">):</span>
        <span class="n">value</span> <span class="o">=</span> <span class="n">bytes_or_str</span><span class="p">.</span><span class="n">decode</span><span class="p">(</span><span class="s">'utf-8'</span><span class="p">)</span>
    <span class="k">else</span><span class="p">:</span>
        <span class="n">value</span> <span class="o">=</span> <span class="n">bytes_or_str</span>
    <span class="k">return</span> <span class="n">value</span> <span class="c1"># Instance of str
</span>
<span class="k">print</span><span class="p">(</span><span class="nb">repr</span><span class="p">(</span><span class="n">to_str</span><span class="p">(</span><span class="s">u'foo'</span><span class="p">)))</span>
<span class="k">print</span><span class="p">(</span><span class="nb">repr</span><span class="p">(</span><span class="n">to_str</span><span class="p">(</span><span class="s">'foo'</span><span class="p">)))</span>

<span class="k">def</span> <span class="nf">to_bytes</span><span class="p">(</span><span class="n">bytes_or_str</span><span class="p">):</span>
    <span class="s">"""жҺҘеҸ—strжҲ–bytes,е№¶жҖ»жҳҜиҝ”еӣһbytes"""</span>
    <span class="k">if</span> <span class="nb">isinstance</span><span class="p">(</span><span class="n">bytes_or_str</span><span class="p">,</span> <span class="nb">str</span><span class="p">):</span>
        <span class="n">value</span> <span class="o">=</span> <span class="n">bytes_or_str</span><span class="p">.</span><span class="n">encode</span><span class="p">(</span><span class="s">'utf-8'</span><span class="p">)</span>
    <span class="k">else</span><span class="p">:</span>
        <span class="n">value</span> <span class="o">=</span> <span class="n">bytes_or_str</span>
    <span class="k">return</span> <span class="n">value</span> <span class="c1"># Instance of bytes
</span>
<span class="k">print</span><span class="p">(</span><span class="nb">repr</span><span class="p">(</span><span class="n">to_bytes</span><span class="p">(</span><span class="s">b'foo'</span><span class="p">)))</span>
<span class="k">print</span><span class="p">(</span><span class="nb">repr</span><span class="p">(</span><span class="n">to_bytes</span><span class="p">(</span><span class="s">'foo'</span><span class="p">)))</span>

<span class="c1"># python2 дёӯзј–еҶҷдёӨдёӘиҫ…еҠ©еҮҪж•°
</span>
<span class="k">def</span> <span class="nf">to_unicode</span><span class="p">(</span><span class="n">unicode_or_str</span><span class="p">):</span>
    <span class="s">"""жҺҘеҸ— str жҲ– unicodeпјҢе№¶жҖ»иҝ”еӣһ Unicode"""</span>
    <span class="k">if</span> <span class="nb">isinstance</span><span class="p">(</span><span class="n">unicode_or_str</span><span class="p">,</span> <span class="nb">str</span><span class="p">):</span>
        <span class="n">value</span> <span class="o">=</span> <span class="n">unicode_or_str</span><span class="p">.</span><span class="n">decode</span><span class="p">(</span><span class="s">'utf-8'</span><span class="p">)</span>
    <span class="k">else</span><span class="p">:</span>
        <span class="n">value</span> <span class="o">=</span> <span class="n">unicode_or_str</span>
    <span class="k">return</span> <span class="n">value</span> <span class="c1">#Instance of unicode
</span>
<span class="k">print</span><span class="p">(</span><span class="nb">repr</span><span class="p">(</span><span class="n">to_unicode</span><span class="p">(</span><span class="s">u'foo'</span><span class="p">)))</span>
<span class="k">print</span><span class="p">(</span><span class="nb">repr</span><span class="p">(</span><span class="n">to_unicode</span><span class="p">(</span><span class="s">'foo'</span><span class="p">)))</span>

<span class="k">def</span> <span class="nf">to</span> <span class="nb">str</span><span class="p">(</span><span class="n">unicode_or_str</span><span class="p">):</span>
    <span class="s">"""жҺҘеҸ— str жҲ– unicodeпјҢе№¶жҖ»иҝ”еӣһ str"""</span>
    <span class="k">if</span> <span class="nb">isinstance</span><span class="p">(</span><span class="n">unicode_or_str</span><span class="p">,</span> <span class="nb">unicode</span><span class="p">):</span>
        <span class="n">value</span> <span class="o">=</span> <span class="n">unicode_or_str</span><span class="p">.</span><span class="n">encode</span><span class="p">(</span><span class="s">'utf-8'</span><span class="p">)</span>
    <span class="k">else</span><span class="p">:</span>
        <span class="n">value</span> <span class="o">=</span> <span class="n">unicode_or_str</span>
    <span class="k">return</span> <span class="n">value</span> <span class="c1">#Instance of str
</span><span class="k">print</span><span class="p">(</span><span class="nb">repr</span><span class="p">(</span><span class="n">to_str</span><span class="p">(</span><span class="s">u'foo'</span><span class="p">)))</span>
<span class="k">print</span><span class="p">(</span><span class="nb">repr</span><span class="p">(</span><span class="n">to_str</span><span class="p">(</span><span class="s">'foo'</span><span class="p">)))</span>
    
</code></pre></div></div>

<ul>
  <li>иҰҒзӮ№
    <ul>
      <li>еңЁ python3дёӯпјҢbytes жҳҜдёҖз§ҚеҢ…еҗ«8дҪҚеҖјзҡ„еәҸеҲ—пјҢstr жҳҜдёҖз§ҚеҢ…еҗ« Unicode еӯ—з¬Ұзҡ„еәҸеҲ—гҖӮејҖеҸ‘иҖ…дёҚиғҪд»Ҙ&gt; жҲ–+ зӯүж“ҚдҪңз¬ҰжқҘж··еҗҢж“ҚдҪң bytes е’Ң str е®һдҫӢ</li>
      <li>еңЁ python2дёӯпјҢstr жҳҜдёҖз§ҚеҢ…еҗ«8дҪҚеҖјзҡ„еәҸеҲ—пјҢUnicodeжҳҜдёҖз§ҚеҢ…еҗ« Unicode еӯ—з¬Ұзҡ„еәҸеҲ—гҖӮеҰӮжһң str еҸӘеҢ…еҗ«7дҪҚ ASCII еӯ—з¬ҰпјҢйӮЈд№ҲеҸҜд»ҘйҖҡиҝҮзӣёе…ізҡ„ж“ҚдҪңз¬ҰжқҘеҗҢж—¶дҪҝз”Ё str дёҺ unicode</li>
      <li>еңЁеҜ№иҫ“е…Ҙзҡ„ж•°жҚ®иҝӣиЎҢж“ҚдҪңд№ӢеүҚпјҢдҪҝз”Ёиҫ…еҠ©еҮҪж•°жқҘдҝқиҜҒеӯ—з¬ҰеәҸеҲ—зҡ„зұ»еһӢдёҺејҖеҸ‘иҖ…зҡ„жңҹжңӣзӣёз¬Ұ</li>
      <li>д»Һж–Үд»¶дёӯиҜ»еҸ–дәҢиҝӣеҲ¶ж•°жҚ®пјҢжҲ–еҗ‘ж–Үд»¶дёӯеҶҷе…ҘдәҢиҝӣеҲ¶ж•°жҚ®ж—¶пјҢжҖ»еә”иҜҘд»ҘвҖҷrbвҖҷжҲ–вҖҷwbвҖҷзӯүдәҢиҝӣеҲ¶жЁЎејҸжқҘејҖеҗҜж–Үд»¶</li>
    </ul>
  </li>
</ul>

<h4 id="04-з”Ёиҫ…еҠ©еҮҪж•°жқҘеҸ–д»ЈеӨҚжқӮзҡ„иЎЁиҫҫејҸ">04. з”Ёиҫ…еҠ©еҮҪж•°жқҘеҸ–д»ЈеӨҚжқӮзҡ„иЎЁиҫҫејҸ</h4>

<p>иҰҒд»Һ URL дёӯи§Јз ҒжҹҘиҜўеӯ—з¬ҰдёІ,еңЁдёӢдҫӢжүҖдёҫзҡ„жҹҘиҜўеӯ—з¬ҰдёІдёӯпјҢжҜҸдёӘеҸӮж•°йғҪеҸҜд»ҘиЎЁзӨәдёҖдёӘж•ҙж•°еҖјгҖӮ</p>

<div class="language-python highlighter-rouge"><div class="highlight"><pre class="highlight"><code>
<span class="kn">from</span> <span class="nn">urllib.parse</span> <span class="kn">import</span> <span class="n">parse_qs</span>

<span class="n">my_values</span> <span class="o">=</span> <span class="n">parse_qs</span><span class="p">(</span><span class="s">'red=5&amp;blue=0&amp;green='</span><span class="p">,</span> <span class="n">keep_blank_values</span><span class="o">=</span><span class="bp">True</span><span class="p">)</span>
<span class="k">print</span><span class="p">(</span><span class="nb">repr</span><span class="p">(</span><span class="n">my_values</span><span class="p">))</span>
<span class="o">&gt;&gt;&gt;</span> <span class="p">{</span><span class="s">'red'</span><span class="p">:</span> <span class="p">[</span><span class="s">'5'</span><span class="p">],</span> <span class="s">'blue'</span><span class="p">:</span> <span class="p">[</span><span class="s">'0'</span><span class="p">],</span> <span class="s">'green'</span><span class="p">:</span> <span class="p">[</span><span class="s">''</span><span class="p">]}</span>

<span class="c1"># зҺ°еңЁиҰҒдҫқж¬ЎеҸ–еҮә red  greep opacity(дёҚеӯҳеңЁзҡ„еҸӮж•°) зҡ„еҖјпјҢеёёи§„еҒҡжі•
</span><span class="n">red</span> <span class="o">=</span> <span class="nb">int</span><span class="p">(</span><span class="n">my_values</span><span class="p">.</span><span class="n">get</span><span class="p">(</span><span class="s">'red'</span><span class="p">,</span> <span class="p">[</span><span class="s">''</span><span class="p">])[</span><span class="mi">0</span><span class="p">]</span> <span class="ow">or</span> <span class="mi">0</span><span class="p">)</span>
<span class="n">green</span> <span class="o">=</span> <span class="nb">int</span><span class="p">(</span><span class="n">my_values</span><span class="p">.</span><span class="n">get</span><span class="p">(</span><span class="s">'green'</span><span class="p">,</span> <span class="p">[</span><span class="s">''</span><span class="p">])[</span><span class="mi">0</span><span class="p">]</span> <span class="ow">or</span> <span class="mi">0</span><span class="p">)</span>
<span class="n">opacity</span> <span class="o">=</span> <span class="nb">int</span><span class="p">(</span><span class="n">my_values</span><span class="p">.</span><span class="n">get</span><span class="p">(</span><span class="s">'opacity'</span><span class="p">,</span> <span class="p">[</span><span class="s">''</span><span class="p">])[</span><span class="mi">0</span><span class="p">]</span> <span class="ow">or</span> <span class="mi">0</span><span class="p">)</span>

<span class="c1"># иЎЁиҫҫејҸжҜ”иҫғй•ҝеҸҜд»Ҙдҝ®ж”№дёә if/else ж–№ејҸиҺ·еҸ–пјҢжңҖеҘҪзҡ„ж–№ејҸжҳҜе°ҒиЈ…жҲҗиҫ…еҠ©еҮҪж•°еҰӮдёӢ
</span>
<span class="k">def</span> <span class="nf">get_first_int</span><span class="p">(</span><span class="n">values</span><span class="p">,</span> <span class="n">key</span><span class="p">,</span> <span class="n">default</span><span class="o">=</span><span class="mi">0</span><span class="p">):</span>
    <span class="n">found</span> <span class="o">=</span> <span class="n">values</span><span class="p">.</span><span class="n">get</span><span class="p">(</span><span class="n">key</span><span class="p">,</span> <span class="p">[</span><span class="s">''</span><span class="p">])</span>
    <span class="k">if</span> <span class="n">found</span><span class="p">[</span><span class="mi">0</span><span class="p">]:</span>
        <span class="n">found</span> <span class="o">=</span> <span class="nb">int</span><span class="p">(</span><span class="n">found</span><span class="p">[</span><span class="mi">0</span><span class="p">]</span>
    <span class="k">else</span><span class="p">:</span>
        <span class="n">found</span> <span class="o">=</span> <span class="n">default</span>
    <span class="k">return</span> <span class="n">found</span>

<span class="c1"># иҺ·еҸ–дёҠйқўзҡ„еҖјеҸӘйңҖиҰҒи°ғз”Ёиҫ…еҠ©ж–№жі•еҚіеҸҜеҰӮ
</span><span class="n">green</span> <span class="o">=</span> <span class="n">get_first_int</span><span class="p">(</span><span class="n">my_values</span><span class="p">,</span> <span class="s">'green'</span><span class="p">)</span>

</code></pre></div></div>

<ul>
  <li>иҰҒзӮ№
    <ul>
      <li>дёҚиҰҒиҝҮеәҰиҝҗз”Ё python иҜӯжі•зү№жҖ§пјҢеҶҷеҮәзү№еҲ«еӨҚжқӮдё”йҡҫд»ҘзҗҶи§Јзҡ„еҚ•иЎҢиЎЁиҫҫејҸ</li>
      <li>жҠҠеӨҚжқӮзҡ„иЎЁиҫҫејҸз§»е…Ҙиҫ…еҠ©еҮҪж•°д№ӢдёӯпјҢеҰӮжһңиҰҒеҸҚеӨҚдҪҝз”ЁеҪўеҗҢзҡ„йҖ»иҫ‘пјҢе°ұеә”иҜҘиҝҷд№ҲеҒҡ</li>
      <li>дҪҝз”Ё if/else иЎЁиҫҫејҸпјҢиҰҒжҜ”з”Ё or жҲ– and иҝҷж ·зҡ„ Boolena ж“ҚдҪңз¬ҰеҶҷжҲҗзҡ„иЎЁиҫҫејҸжӣҙеҠ жё…жҘҡ</li>
    </ul>
  </li>
</ul>

<h4 id="05-дәҶи§ЈеҲҮеүІеәҸеҲ—зҡ„ж–№жі•">05. дәҶи§ЈеҲҮеүІеәҸеҲ—зҡ„ж–№жі•</h4>

<p>еҲҮеүІж“ҚдҪңзҡ„еҹәжң¬еҶҷжі•жҳҜ somelist[start:end], е…¶дёӯ start(иө·е§Ӣзҙўеј•)жүҖжҢҮзҡ„е…ғзҙ ж¶өзӣ–еңЁеҲҮеүІеҗҺзҡ„иҢғеӣҙеҶ…пјҢиҖҢ end(з»“жқҹзҙўеј•)жүҖжҢҮзҡ„е…ғзҙ дёҚеҢ…жӢ¬еңЁеҲҮеүІз»“жһңд№ӢдёӯгҖӮ</p>

<ul>
  <li>иҰҒзӮ№
    <ul>
      <li>дёҚиҰҒеҶҷеӨҡдҪҷзҡ„д»Јз ҒпјҡеҪ“ startзҙўеј•дёә0пјҢжҲ– end зҙўеј•дёәеәҸеҲ—й•ҝеәҰж—¶пјҢеә”иҜҘе°Ҷе…¶зңҒз•Ҙ</li>
      <li>еҲҮзүҮж“ҚдҪңдёҚдјҡи®Ўиҫғ start дёҺ end зҙўеј•жҳҜеҗҰи¶Ҡз•ҢпјҢиҝҷдҪҝеҫ—еҫҲе®№жҳ“е°ұиғҪд»ҺеәҸеҲ—зҡ„еүҚз«ҜжҲ–еҗҺз«ҜејҖе§ӢпјҢеҜ№е…¶иҝӣиЎҢиҢғеӣҙеӣәе®ҡзҡ„еҲҮзүҮж“ҚдҪңпјҲa[:20] жҲ– a[-20:]пјү</li>
      <li>еҜ№ list иөӢеҖјзҡ„ж—¶еҖҷпјҢеҰӮжһңдҪҝз”ЁеҲҮзүҮж“ҚдҪңпјҢе°ұдјҡжҠҠеҺҹеҲ—иЎЁдёӯеӨ„еңЁзӣёе…іиҢғеӣҙеҶ…зҡ„еҖјжӣҝжҚўжҲҗж–°еҖјпјҢеҚідҫҝе®ғд»¬зҡ„й•ҝеәҰдёҚеҗҢд№ҹдҫқз„¶еҸҜд»ҘжӣҝжҚў</li>
    </ul>
  </li>
</ul>

<h4 id="06-еңЁеҚ•иҜҚеҲҮзүҮж“ҚдҪңеҶ…дёҚиҰҒеҗҢж—¶еҲ¶е®ҡ-startend-е’Ң-stride">06. еңЁеҚ•иҜҚеҲҮзүҮж“ҚдҪңеҶ…пјҢдёҚиҰҒеҗҢж—¶еҲ¶е®ҡ startгҖҒend е’Ң stride</h4>

<ul>
  <li>иҰҒзӮ№
    <ul>
      <li>еҚіжңү start е’Ң end,еҸҲжңү stride зҡ„еҲҮеүІж“ҚдҪңпјҢеҸҜиғҪдјҡд»Өдәәиҙ№и§Ј</li>
      <li>е°ҪйҮҸдҪҝз”Ё stride дёәжӯЈеҖјпјҢдё”дёҚеёҰ start жҲ– end зҙўеј•зҡ„еҲҮеүІж“ҚдҪңгҖӮзІҫиүҜйҒҝе…ҚдҪҝз”Ёиҙҹж•°еҒҡ stride.</li>
      <li>еңЁеҗҢдёҖдёӘеҲҮзүҮж“ҚдҪңеҶ…пјҢдёҚиҰҒеҗҢж—¶дҪҝз”Ё start, end е’Ң strideгҖӮеҰӮжһңзЎ®е®һйңҖиҰҒжү§иЎҢиҝҷж ·зҡ„ж“ҚдҪңпјҢйӮЈе°ұиҖғиҷ‘е°Ҷе…¶жӢҶи§ЈдёәдёӨжқЎиөӢеҖјиҜӯеҸҘпјҢе…¶дёӯдёҖжқЎдҪңиҢғеӣҙеҲҮеүІпјҢеҸҰдёҖжқЎеҒҡжӯҘиҝӣеҲҮеүІпјҢжҲ–иҖғиҷ‘дҪҝз”ЁеҶ…зҪ® itertools жЁЎеқ—дёӯзҡ„ islice</li>
    </ul>
  </li>
</ul>

<h4 id="07-з”ЁеҲ—иЎЁжҺЁеҜјејҸеҸ–д»Ј-map-е’Ң-filter">07. з”ЁеҲ—иЎЁжҺЁеҜјејҸеҸ–д»Ј map е’Ң filter</h4>

<div class="language-python highlighter-rouge"><div class="highlight"><pre class="highlight"><code><span class="c1"># еҰӮдёӢдҫӢ еёҢжңӣиҺ·еҸ– a зҡ„жҜҸдёӘж•°зҡ„е№іж–№
</span>
<span class="n">a</span> <span class="o">=</span> <span class="p">[</span><span class="mi">1</span><span class="p">,</span> <span class="mi">2</span><span class="p">,</span> <span class="mi">3</span><span class="p">,</span> <span class="mi">4</span><span class="p">,</span> <span class="mi">5</span><span class="p">,</span> <span class="mi">6</span><span class="p">,</span> <span class="mi">7</span><span class="p">,</span> <span class="mi">8</span><span class="p">,</span> <span class="mi">9</span><span class="p">,</span> <span class="mi">10</span><span class="p">]</span>
<span class="n">squares</span> <span class="o">=</span> <span class="p">[</span><span class="n">x</span><span class="o">**</span><span class="mi">2</span> <span class="k">for</span> <span class="n">x</span> <span class="ow">in</span> <span class="n">a</span><span class="p">]</span> <span class="c1"># еҲ—иЎЁжҺЁеҜјејҸе®һзҺ°
</span>
<span class="n">squares</span> <span class="o">=</span> <span class="nb">map</span><span class="p">(</span><span class="k">lambda</span> <span class="n">x</span><span class="p">:</span> <span class="n">x</span><span class="o">**</span><span class="mi">2</span><span class="p">,</span> <span class="n">a</span><span class="p">)</span> <span class="c1"># map еҠ  lambda е®һзҺ°
</span>

<span class="c1"># еҰӮжһңеҸӘйңҖиҰҒиҺ·еҸ–еҸҜд»Ҙиў«2ж•ҙйҷӨзҡ„ж•°
</span><span class="n">even_squares</span> <span class="o">=</span> <span class="p">[</span><span class="n">x</span><span class="o">**</span><span class="mi">2</span> <span class="k">for</span> <span class="n">x</span> <span class="ow">in</span> <span class="n">a</span> <span class="k">if</span> <span class="n">x</span> <span class="o">%</span> <span class="mi">2</span> <span class="o">==</span> <span class="mi">0</span><span class="p">]</span>
<span class="n">even_squares</span> <span class="o">=</span> <span class="nb">map</span><span class="p">(</span><span class="k">lambda</span> <span class="n">x</span><span class="p">:</span> <span class="n">x</span><span class="o">**</span><span class="mi">2</span><span class="p">,</span> <span class="nb">filter</span><span class="p">(</span><span class="k">lambda</span> <span class="n">x</span><span class="p">:</span> <span class="n">x</span> <span class="o">%</span> <span class="mi">2</span> <span class="o">==</span> <span class="mi">0</span><span class="p">,</span> <span class="n">a</span><span class="p">))</span>

<span class="c1"># еӯ—е…ёд№ҹж”ҜжҢҒжҺЁеҜјеҲ—иЎЁ
</span><span class="n">In</span> <span class="p">[</span><span class="mi">1</span><span class="p">]:</span> <span class="n">chile_ranks</span> <span class="o">=</span> <span class="p">{</span><span class="s">'ghost'</span><span class="p">:</span><span class="mi">1</span><span class="p">,</span> <span class="s">'habanero'</span><span class="p">:</span> <span class="mi">2</span><span class="p">,</span> <span class="s">'cayenne'</span><span class="p">:</span> <span class="mi">3</span><span class="p">}</span>

<span class="n">In</span> <span class="p">[</span><span class="mi">2</span><span class="p">]:</span> <span class="p">{</span><span class="n">rank</span><span class="p">:</span><span class="n">name</span> <span class="k">for</span> <span class="n">name</span><span class="p">,</span> <span class="n">rank</span> <span class="ow">in</span> <span class="n">chile_ranks</span><span class="p">.</span><span class="n">items</span><span class="p">()}</span>
<span class="n">Out</span><span class="p">[</span><span class="mi">2</span><span class="p">]:</span> <span class="p">{</span><span class="mi">1</span><span class="p">:</span> <span class="s">'ghost'</span><span class="p">,</span> <span class="mi">2</span><span class="p">:</span> <span class="s">'habanero'</span><span class="p">,</span> <span class="mi">3</span><span class="p">:</span> <span class="s">'cayenne'</span><span class="p">}</span>

<span class="n">In</span> <span class="p">[</span><span class="mi">3</span><span class="p">]:</span> <span class="p">{</span><span class="nb">len</span><span class="p">(</span><span class="n">name</span><span class="p">)</span> <span class="k">for</span> <span class="n">name</span> <span class="ow">in</span> <span class="n">chile_ranks</span><span class="p">.</span><span class="n">keys</span><span class="p">()}</span>
<span class="n">Out</span><span class="p">[</span><span class="mi">3</span><span class="p">]:</span> <span class="p">{</span><span class="mi">5</span><span class="p">,</span> <span class="mi">7</span><span class="p">,</span> <span class="mi">8</span><span class="p">}</span>
</code></pre></div></div>

<ul>
  <li>иҰҒзӮ№
    <ul>
      <li>еҲ—иЎЁжҺЁеҜјиҰҒжҜ”еҶ…зҪ®зҡ„ map е’Ң filter еҮҪж•°жё…жҷ°пјҢеӣ дёәж— йңҖйўқеӨ–зј–еҶҷ lambda иЎЁиҫҫејҸ</li>
      <li>еҲ—иЎЁжҺЁеҜјејҸеҸҜд»Ҙи·іиҝҮиҫ“е…ҘеҲ—иЎЁдёӯзҡ„жҹҗдәӣеҺҹе§ӢпјҢеҰӮжһңж”№з”Ё map жқҘеҒҡпјҢеҝ…йЎ»иҫ…д»Ҙ filter ж–№иғҪе®һзҺ°</li>
      <li>еӯ—е…ёд№ҹж”ҜжҢҒжҺЁеҜјеҲ—иЎЁ</li>
    </ul>
  </li>
</ul>

<h4 id="08-дёҚиҰҒдҪҝз”Ёеҗ«жңүдёӨдёӘд»ҘдёҠиЎЁиҫҫејҸзҡ„еҲ—иЎЁжҺЁеҜј">08. дёҚиҰҒдҪҝз”Ёеҗ«жңүдёӨдёӘд»ҘдёҠиЎЁиҫҫејҸзҡ„еҲ—иЎЁжҺЁеҜј</h4>

<ul>
  <li>иҰҒзӮ№пјҡ
    <ul>
      <li>еҲ—иЎЁжҺЁеҜјж”ҜжҢҒеӨҡзә§еҫӘзҺҜпјҢжҜҸдёҖзә§еҫӘзҺҜд№ҹж”ҜжҢҒеӨҡйЎ№жқЎд»¶</li>
      <li>и¶…иҝҮдёӨдёӘиЎЁиҫҫејҸзҡ„еҲ—иЎЁжҺЁеҜјжҳҜеҫҲйҡҫзҗҶи§Јзҡ„пјҢеә”иҜҘе°ҪйҮҸйҒҝе…Қ</li>
    </ul>
  </li>
</ul>

<h4 id="09-з”Ёз”ҹжҲҗеҷЁиЎЁиҫҫејҸжқҘж”№еҶҷж•°жҚ®йҮҸиҫғеӨ§зҡ„еҲ—иЎЁжҺЁеҜј">09. з”Ёз”ҹжҲҗеҷЁиЎЁиҫҫејҸжқҘж”№еҶҷж•°жҚ®йҮҸиҫғеӨ§зҡ„еҲ—иЎЁжҺЁеҜј</h4>

<p>еҲ—иЎЁжҺЁеҜјзҡ„зјәзӮ№пјҡеҰӮжһңиҫ“е…Ҙзҡ„ж•°жҚ®йқһеёёеӨҡпјҢйӮЈд№ҲеҸҜиғҪдјҡж¶ҲиҖ—еӨ§йҮҸеҶ…еӯҳпјҢе№¶еҜјиҮҙзЁӢеәҸеҙ©жәғгҖӮ</p>

<p>еҒҮи®ҫ /tmp/myfile.txt ж–Үд»¶жңүеҮ иЎҢж•°жҚ®пјҢжҜҸиЎҢж•°жҚ®зҡ„й•ҝеәҰдёә 100, 57, 14, 1, 4</p>

<div class="language-python highlighter-rouge"><div class="highlight"><pre class="highlight"><code><span class="c1"># е°‘йҮҸзҡ„ж•°жҚ®иҫ“е…Ҙ
</span><span class="n">value</span> <span class="o">=</span> <span class="p">[</span><span class="nb">len</span><span class="p">(</span><span class="n">x</span><span class="p">)</span> <span class="k">for</span> <span class="n">x</span> <span class="ow">in</span> <span class="nb">open</span><span class="p">(</span><span class="s">'/tmp/myfile.txt'</span><span class="p">)]</span>
<span class="k">print</span><span class="p">(</span><span class="n">value</span><span class="p">)</span>
